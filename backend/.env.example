# Fixetta.ai Backend Environment Variables

# OpenRouter API Key (for Gemini & Claude access)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Craftsman National Estimator API (for regional cost data)
# Get your API key at: https://www.craftsman-book.com/api
CRAFTSMAN_API_KEY=your_craftsman_api_key_here
CRAFTSMAN_API_URL=https://api.craftsman-book.com/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
